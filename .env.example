# Example environment overrides for RateShield.
# Copy to `.env` and adjust if you want to use your own credentials.
# All values are OPTIONAL — docker-compose and the dev profile fall back to
# the defaults shown here when no variable is set, so the app runs with no
# .env file at all.

# PostgreSQL / datasource
DB_USERNAME=rateshield
DB_PASSWORD=rateshield

# Application security accounts
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
OPS_USERNAME=ops
OPS_PASSWORD=ops123
